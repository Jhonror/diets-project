# Copia a .env y rellena. No subas .env a Git.
#
# Supabase → Project Settings → API:
# - Project URL → SUPABASE_URL (ej. https://abcdefghij.supabase.co)
# - Publishable (sb_publishable_...) o Legacy → anon (eyJ...)
# - Secret (sb_secret_...) o Legacy → service_role — solo local para npm run seed

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional (npm run seed): mismos correos que en Authentication → Users
# SEED_EMAIL_KAREN=cliente1@example.com
# SEED_EMAIL_JHON=cliente2@example.com
